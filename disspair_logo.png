<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="100%" height="100%">
  <defs>
    <!-- Stealth Dark Mode Background Gradient -->
    <radialGradient id="bgGlow" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1a1a24"/>
      <stop offset="100%" stop-color="#070707"/>
    </radialGradient>

    <!-- Cyberpunk Neon Glow Filters -->
    <filter id="glowCyan" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
    
    <filter id="glowRed" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>

    <!-- Diagonal Cut Clip Paths (y = x) -->
    <!-- Top-Right Region -->
    <clipPath id="topRight">
      <polygon points="-100,-100 600,-100 600,600" />
    </clipPath>
    <!-- Bottom-Left Region -->
    <clipPath id="bottomLeft">
      <polygon points="-100,-100 -100,600 600,600" />
    </clipPath>

    <!-- Continuous Standard Bluetooth Rune Path -->
    <path id="bt-icon" 
          d="M 190 190 L 250 250 L 310 190 L 250 130 L 250 370 L 310 310 L 250 250 L 190 310" 
          fill="none" 
          stroke-width="28" 
          stroke-linecap="round" 
          stroke-linejoin="round"/>
  </defs>

  <!-- Base App Icon Background -->
  <rect width="500" height="500" rx="90" fill="url(#bgGlow)" stroke="#22222a" stroke-width="4"/>

  <!-- ========================================== -->
  <!-- TOP RIGHT FRACTURE (SAFE / CONNECTED)      -->
  <!-- ========================================== -->
  <g transform="translate(12, -12)">
    <g clip-path="url(#topRight)">
      <!-- Vulnerability Scanner Radar Rings -->
      <circle cx="250" cy="250" r="90" fill="none" stroke="#00E5FF" stroke-width="1" opacity="0.3"/>
      <circle cx="250" cy="250" r="150" fill="none" stroke="#00E5FF" stroke-width="2" stroke-dasharray="10 15" opacity="0.15"/>
      <circle cx="320" cy="180" r="4" fill="#00E5FF"/>
      <circle cx="280" cy="140" r="3" fill="#00E5FF"/>
      
      <!-- Cyan Bluetooth Half -->
      <use href="#bt-icon" stroke="#00E5FF" filter="url(#glowCyan)"/>
    </g>
  </g>

  <!-- ========================================== -->
  <!-- BOTTOM LEFT FRACTURE (ATTACK / CRASHED)    -->
  <!-- ========================================== -->
  <g transform="translate(-12, 12)">
    <g clip-path="url(#bottomLeft)">
      <!-- Warning Radar Rings -->
      <circle cx="250" cy="250" r="90" fill="none" stroke="#FF0055" stroke-width="1" opacity="0.3"/>
      <circle cx="250" cy="250" r="150" fill="none" stroke="#FF0055" stroke-width="2" stroke-dasharray="10 15" opacity="0.15"/>
      <circle cx="180" cy="320" r="4" fill="#FF0055"/>
      <circle cx="220" cy="360" r="3" fill="#FF0055"/>
      
      <!-- Neon Red Bluetooth Half -->
      <use href="#bt-icon" stroke="#FF0055" filter="url(#glowRed)"/>
    </g>
  </g>

  <!-- ========================================== -->
  <!-- THE "SEVERED CONNECTION" SLASH BEAM        -->
  <!-- ========================================== -->
  <!-- Glowing core cut -->
  <line x1="80" y1="80" x2="420" y2="420" stroke="#FFFFFF" stroke-width="6" opacity="0.9" filter="url(#glowCyan)"/>
  <!-- Glitch offset red cut -->
  <line x1="85" y1="75" x2="425" y2="415" stroke="#FF0055" stroke-width="2" opacity="0.8"/>

  <!-- ========================================== -->
  <!-- MINOR CYBERPUNK GLITCH ARTIFACTS           -->
  <!-- ========================================== -->
  <rect x="150" y="240" width="30" height="6" fill="#00E5FF" opacity="0.7"/>
  <rect x="320" y="260" width="40" height="6" fill="#FF0055" opacity="0.7"/>
  <rect x="230" y="380" width="15" height="4" fill="#FF0055" opacity="0.5"/>
  <rect x="255" y="110" width="20" height="4" fill="#00E5FF" opacity="0.5"/>

  <!-- ========================================== -->
  <!-- DISS-PAIR APP TITLE TEXT                   -->
  <!-- ========================================== -->
  <text x="250" y="465" font-family="'Segoe UI', Helvetica, Arial, sans-serif" font-weight="900" font-size="46" text-anchor="middle" letter-spacing="4">
    <tspan fill="#00E5FF" filter="url(#glowCyan)">DISS</tspan><tspan fill="#FF0055" filter="url(#glowRed)">PAIR</tspan>
  </text>
  
</svg>